// Initialize the display object
Adafruit_ST7789 tft = Adafruit_ST7789(TFT_CS, TFT_DC, TFT_RST);

void setup(void) {
  // 1. Turn on the backlight immediately
  pinMode(BACKLIGHT, OUTPUT);
  digitalWrite(BACKLIGHT, HIGH); 

  tft.init(240, 240, SPI_MODE2); 

  // 3. Fix "Inverted" colors (Standard for many ST7789 modules)
  tft.invertDisplay(true);
  
  main_screen();

}

void loop() {
  // Stay pink!
}


void main_screen(void) {
    tft.fillScreen(0x0); // Change gfx-> to tft.

    // rect 1
    tft.fillRect(0, 1, 239, 237, rect_1_color);

        // Dynamic selection rectangle
    if (AUTO_ON) {
        // Around Map (Coordinates adjusted for your map bitmap)
        tft.drawRoundRect(130, 124, 60, 54, 4, 0xFFFF); // White border
    } else {
        // Around Smartphone (Coordinates adjusted for your phone bitmap)
        tft.drawRoundRect(48, 122, 33, 54, 4, 0xFFFF);
    }

    // string 2
    tft.setTextColor(0x0);
    tft.setTextSize(2);
    tft.setTextWrap(false);
    tft.setFont(&FreeMonoBold9pt7b);
    tft.setCursor(28, 61);
    tft.println("Zhorzhik");

    // string 2 copy 1
    tft.setTextSize(1);
    tft.setCursor(79, 82);
    tft.println("on move");

    // smartphone
    tft.drawBitmap(31, 110, image_smartphone_bits, 54, 96, 0x0);

    // map
    tft.drawBitmap(109, 118, image_map_bits, 108, 96, 0x0);

    // music_radio_streaming
    tft.drawBitmap(41, 139, image_music_radio_streaming_bits, 34, 32, 0x0);
}


